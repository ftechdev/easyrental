# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<appName>

# Server
PORT=5000
DEBUG=true

# JWT Secrets
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

GOOGLE_ANDROID_CLIENT_ID=google_android_client_id_here
GOOGLE_IOS_CLIENT_ID=google_ios_client_id_here


# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/facebook/callback

# Apple OAuth
APPLE_CLIENT_ID=your_apple_service_id_here
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_KEY_ID=your_apple_key_id_here
APPLE_CALLBACK_URL=http://localhost:5000/api/auth/apple/callback
APPLE_PRIVATE_KEY_PATH=path/to/apple/private/key.p8

# Frontend URL
FRONTEND_URL=http://localhost:8080

# Session
SESSION_SECRET=your_session_secret_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Gmail App SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=artcreativity2020@gmail.com
SMTP_PASS=your_google_app_password_here
SMTP_FROM=bookings@easyrental.com

# Admin Email
ADMIN_EMAIL=admin1@example.com,admin2@example.com

# Email Verification
EMAIL_VERIFICATION_SECRET=your_email_verification_secret_here
EMAIL_USER=artcreativity2020@gmail.com
EMAIL_PASS=your_google_app_password_here

# Password Reset
RESET_PASSWORD_SECRET=your_reset_password_secret_here

# Stripe Keys
STRIPE_SECRET_KEY_TEST=your_test_stripe_secret_key
STRIPE_SECRET_KEY_LIVE=your_live_stripe_secret_key

# Tabby keys
TABBY_SECRET_KEY=your_tabby_public_key_here
MERCHANT_CODE=your_tabby_merchant_code_here
TABBY_API_BASE_URL=https://api.tabby.ai # For Live
# For Test/Sandbox:
# TABBY_API_BASE_URL=https://api.tabby.ai/sandbox # (Confirm this with Tabby)

# Direct WhatsApp Configuration
WHATSAPP_TARGET_NUMBER=+971559254955 # Default recipient for booking notifications
WHATSAPP_SESSION_PATH=./.wwebjs_auth # Path to store WhatsApp session files
WHATSAPP_ENABLE_QR=true # Enable QR code generation for authentication

# Resend Email Service (for booking notifications)
RESEND_API_KEY=your_resend_api_key_here